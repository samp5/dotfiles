{
    "layer": "top",
    "output": "eDP-1",
    "modules-left": ["custom/scratchpad-indicator","sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory","temperature","custom/wl-gammarelay-temperature", "backlight","network","bluetooth","pulseaudio", "battery"],
    "sway/workspaces": {
      "format": "{name}"
    },
    "sway/mode": {
      "format": "󰌌  {}"
    },
    "custom/cider": {
      "interval": 1,
      "return-type": "json",
      "on-click":"playerctl -p cider play-pause",
      "on-click-right": "killall cider",
      "smooth-scrolling-threshold": 10, 
      "on-scroll-up" : "playerctl -p cider previous",
      "on-scroll-down" : "playerctl -p cider next",
      "exec": "~/dotfiles/sway/waybar/modules/cider.sh",
      "exec-if": "pgrep Cider",
      "escape": true
    },
    "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-bluetooth": "{volume}% {icon}",
      "format-muted": " ",
      "format-icons": {
        "headphone": " ",
        "headset": "󰋎 ",
        "default":  " "
      },
      "scroll-step": 1,
      "on-click": "pavucontrol",
      "ignored-sinks": ["Easy Effects Sink"]
    },
    "custom/scratchpad-indicator": {
      "interval": 3,
      "return-type": "json",
      "exec": "swaymsg -t get_tree | jq --unbuffered --compact-output '(recurse(.nodes[]) | select(.name == \"__i3_scratch\") | .focus) as $scratch_ids | [..  | (.nodes? + .floating_nodes?) // empty | .[] | select(.id |IN($scratch_ids[]))] as $scratch_nodes | if ($scratch_nodes|length) > 0 then { text: \"\\($scratch_nodes | length)\", tooltip: $scratch_nodes | map(\"\\(.app_id // .window_properties.class) (\\(.id)): \\(.name)\") | join(\"\\n\") } else empty end'",
      "format": "{} 🗗",
      "on-click": "exec swaymsg 'scratchpad show'",
      "on-click-right": "exec swaymsg 'move scratchpad'"
    },
    "network":{
      "on-click": "~/dotfiles/sway/scripts/wifi_script",
      "format": " {ifname}",
      "tooltip-format": "Network: {essid} ({signalStrength})\n󱀣 {netmask}\n󰺆 {gwaddr}\n󰲐 {ipaddr}",
      "format-disconnected": " ",
    },
    "cpu": {
      "on-click": "alacritty -e btop",
       "interval": 1,
       "format": "󰍛 : {icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}",
       "format-icons": [
            "<span color='#76946a'>▁</span>", // wintergreen
            "<span color='#76946a'>▂</span>", // autumngreen
            "<span color='#76946a'>▃</span>", // 
            "<span color='#DCA561'>▄</span>", // white
            "<span color='#DCA561'>▅</span>", // yellow
            "<span color='#DCA561'>▆</span>", // yellow
            "<span color='#C34043'>▇</span>", // orange
            "<span color='#C34043'>█</span>"  // red
       ]
    },
    "battery": {
        "interval": 10,
        "states":{
          "warning": 30,
          "critical": 15,
        },
        "format": "{capacity}% {icon} ",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo}\nDrawing {power}W",
    },
    "bluetooth": {
      "on-click": "~/dotfiles/sway/scripts/floatthatmf \"alacritty -e bluetui\"",
      "format": " {status}",
      "format-connected": " {device_alias}",
      "format-connected-battery": " {device_alias} {device_battery_percentage}%",
      "format-device-preference": [ "device1", "device2" ],
      "tooltip-format": "{controller_alias}: {controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}: {controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
    },
    "clock": {
      "interval": 60,
      "format": "{:%d %I:%M}",
      "format-alt": "{:%a, %d. %b  %I:%M}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode"          : "month",
        "mode-mon-col"  : 3,
        "weeks-pos"     : "left",
        "format": {
          "months":     "<span color='#658594'><b>{}</b></span>",
          "days":       "<span color='#dcd7ba'><b>{}</b></span>",
          "weeks":      "<span color='#ff9e3b'><b>W{}</b></span>",
          "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
          "today":      "<span color='#7aa89f'><b><u>{}</u></b></span>"
        }
      },
      "actions":  {
        "on-click-right": "mode",
        "on-scroll-up": "tz_up",
        "on-scroll-down": "tz_down",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
      }
    },
    "memory": {
      "on-click": "alacritty -e btop",
      "interval": 3,
      
      "format": "  {used} GB",
      "tooltip-format": "{used:0.1f}G/{total:0.1f}G {percentage}%\nSwap: {swapUsed:0.1f}G/{swapTotal:0.1f}G",
    },
    "temperature": {
      "on-click": "wezterm start gotop",
      "format": "{temperatureC}°C",
      "critical-threshold": 70,
      "format-critical": "󰠨 {temperatureC}°C" ,
    },
     "custom/wl-gammarelay-temperature": {
        "format": "{} ",
        "exec": "/home/sam/.cargo/bin/wl-gammarelay-rs watch {t}",
        "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +50",
        "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -50"
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{percent}% {icon}",
      "format-icons": ["󰃞","󰃟", "󰃝","󰃠"]
    },
}
