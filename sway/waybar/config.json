{
    "layer": "top",
    "margin-left": 6,
    "margin-right": 6,
    "reload_style_on_change": true,
    "margin-top": 2,
    "modules-left": ["niri/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory","temperature","custom/wl-gammarelay-temperature", "backlight","network","bluetooth","pulseaudio", "battery"],
    "custom/cider": {
      "interval": 1,
      "return-type": "json",
      "on-click":"playerctl -p cider play-pause",
      "on-click-right": "killall cider",
      "smooth-scrolling-threshold": 10, 
      "on-scroll-up" : "playerctl -p cider previous",
      "on-scroll-down" : "playerctl -p cider next",
      "exec": "~/dotfiles/sway/waybar/modules/cider.sh",
      "exec-if": "pgrep Cider",
      "escape": true
    },
    "niri/workspaces": {
      "format": "{index} {icon}",
    	"format-icons": {
        "a_code": " ",
        "b_browser": "󰖟 ",
        "active": " ",
        "default": " "
      },
      "all-outputs": false,
    },
    "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-bluetooth": "{volume}% {icon}",
      "format-muted": " ",
      "format-icons": {
        "headphone": " ",
        "headset": "󰋎 ",
        "default":  " "
      },
      "scroll-step": 1,
      "on-click": "pavucontrol",
      "ignored-sinks": ["Easy Effects Sink"]
    },
    "network":{
      "format": " {ifname}",
      "tooltip-format": "Network: {essid} ({signalStrength})\n󱀣 {netmask}\n󰺆 {gwaddr}\n󰲐 {ipaddr}",
      "format-disconnected": " "
    },
    "cpu": {
      "on-click": "alacritty -e btop",
       "interval": 1,
       "format": "󰍛 : {icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7}",
       "format-icons": [
            "<span color='#76946a'>▁</span>",
            "<span color='#76946a'>▂</span>",
            "<span color='#76946a'>▃</span>",
            "<span color='#DCA561'>▄</span>",
            "<span color='#DCA561'>▅</span>",
            "<span color='#DCA561'>▆</span>",
            "<span color='#C34043'>▇</span>",
            "<span color='#C34043'>█</span>" 
       ]
    },
    "battery": {
        "interval": 10,
        "states":{
          "warning": 30,
          "critical": 15,
        },
        "format": "{capacity}% {icon} ",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo}\nDrawing {power}W",
    },
    "bluetooth": {
      "on-click": "\"alacritty -e bluetui\"",
      "format": " {status}",
      "format-connected": " {device_alias}",
      "format-connected-battery": " {device_alias} {device_battery_percentage}%",
      "format-device-preference": [ "device1", "device2" ],
      "tooltip-format": "{controller_alias}: {controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}: {controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
    },
    "clock": {
      "interval": 60,
      "format": "{:%d %I:%M}",
      "format-alt": "{:%a, %d. %b  %I:%M}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode"          : "month",
        "mode-mon-col"  : 3,
        "weeks-pos"     : "left",
        "format": {
          "months":     "<span color='#658594'><b>{}</b></span>",
          "days":       "<span color='#dcd7ba'><b>{}</b></span>",
          "weeks":      "<span color='#ff9e3b'><b>W{}</b></span>",
          "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
          "today":      "<span color='#7aa89f'><b><u>{}</u></b></span>"
        }
      },
      "actions":  {
        "on-click-right": "mode",
        "on-scroll-up": "tz_up",
        "on-scroll-down": "tz_down"
      }
    },
    "memory": {
      "interval": 3,
      
      "format": "  {used} GB",
      "tooltip-format": "{used:0.1f}G/{total:0.1f}G {percentage}%\nSwap: {swapUsed:0.1f}G/{swapTotal:0.1f}G"
    },
    "temperature": {
      "format": "{temperatureC}°C",
      "critical-threshold": 70,
      "format-critical": "󰠨 {temperatureC}°C" 
    },
     "custom/wl-gammarelay-temperature": {
        "format": "{} ",
        "exec": "/home/sam/.cargo/bin/wl-gammarelay-rs watch {t}",
        "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +50",
        "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -50"
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{percent}% {icon}",
      "format-icons": ["󰃞","󰃟", "󰃝","󰃠"]
    }
}
